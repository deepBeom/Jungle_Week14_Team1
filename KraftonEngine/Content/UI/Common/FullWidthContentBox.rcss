.full-width-content-box {
	position: absolute;
	left: 0px;
	width: 100%;
	height: auto;
	padding-top: 40px;
	padding-bottom: 40px;
	background-color: rgba(12, 12, 12, 0.96);
	overflow: visible;
}

.full-width-content-box-screen-center {
	top: 50%;
	margin-top: -160px;
	padding-top: 40px;
	padding-bottom: 40px;
}

.full-width-content-box-content {
	position: relative;
	margin-left: auto;
	margin-right: auto;
	width: auto;
	height: auto;
	overflow: visible;
}
