.hover-image-button {
	position: absolute;
	overflow: visible;
}

@keyframes hover-image-box-blink {
	0% {
		opacity: 0.95;
	}
	50% {
		opacity: 0.38;
	}
	100% {
		opacity: 0.95;
	}
}

.hover-image-box {
	display: block;
	position: absolute;
	left: 0px;
	top: -6%;
	width: 100%;
	height: 105%;
	image-fit: fill;
	opacity: 0.0;
}

.hover-image-label {
	position: absolute;
	left: 10px;
	top: 0px;
	width: 100%;
	height: 100%;
	color: #858585;
	line-height: 100%;
	white-space: nowrap;
	text-shadow: none;
}

.hover-image-button:hover .hover-image-box {
	opacity: 0.95;
	animation-name: hover-image-box-blink;
	animation-duration: 0.58s;
	animation-iteration-count: infinite;
	animation-direction: alternate;
	animation-timing-function: ease-in-out;
}

.hover-image-button:hover .hover-image-label {
	color: #111111;
	animation-name: none;
	text-shadow: none;
}
