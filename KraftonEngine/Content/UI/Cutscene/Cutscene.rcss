body {
	margin: 0px;
	width: 100%;
	height: 100%;
	font-family: Pretendard;
	color: #ffffff;
}

#cutscene-root {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	pointer-events: none;
}

.letterbox-bar {
	position: absolute;
	left: 0px;
	width: 100%;
	height: 13.5%;
	background-color: #000000;
	opacity: 0.96;
}

#letterbox-top {
	top: 0px;
}

#letterbox-bottom {
	bottom: 0px;
}

.cutscene-dialogue-box {
	left: 50%;
	bottom: 118px;
	padding: 7px 14px;
	background-color: #101010A8;
	opacity: 0.0;
}

.cutscene-dialogue-text {
	display: block;
	width: 100%;
	font-family: Pretendard;
	font-size: 12px;
	font-weight: 400;
	line-height: 17px;
	color: #ffffff;
	white-space: normal;
}

.skip-ring {
	position: absolute;
	right: 54px;
	bottom: 112px;
	width: 64px;
	height: 64px;
	opacity: 0.0;
}

.skip-ring-frame {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 64px;
	height: 64px;
	image-fit: contain;
	opacity: 0.0;
}
