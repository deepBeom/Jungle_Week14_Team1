body {
	margin: 0px;
	width: 100%;
	height: 100%;
	font-family: Pretendard;
	color: #f5f2eeE6;
}

@keyframes menu-hover-blink {
	0% {
		color: #ffffffE6;
	}
	50% {
		color: #707070E6;
	}
	100% {
		color: #ffffffE6;
	}
}

#title-screen {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	overflow: hidden;
	background-color: #050505;
}

#title-background {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	image-fit: cover;
}

#shade {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	background-color: #00000000;
}

#main-menu {
	position: absolute;
	left: 7.2%;
	top: 22.7%;
	width: 72.7%;
	height: 50.0%;
}

#game-title {
	font-size: 104px;
	font-weight: 900;
	line-height: 112px;
	letter-spacing: 0px;
	color: #FAFAFAE6;
	white-space: nowrap;
}

.menu-block {
	margin-bottom: 26px;
}

.menu-primary {
	font-size: 54px;
	font-weight: 700;
	line-height: 100%;
	color: #858585E6;
	white-space: nowrap;
	overflow: visible;
}

.menu-primary:hover {
	color: #ffffffE6;
	animation-name: menu-hover-blink;
	animation-duration: 0.58s;
	animation-iteration-count: infinite;
	animation-direction: alternate;
	animation-timing-function: ease-in-out;
	text-shadow: none;
}

#start-actions {
	display: block;
	margin-top: 8px;
}

.menu-node {
	color: #f5f2eeE6;
	overflow: visible;
}

.menu-child {
	font-size: 34px;
	font-weight: 400;
	line-height: 100%;
	color: #858585E6;
	white-space: nowrap;
	overflow: visible;
}

.menu-child:hover {
	color: #ffffffE6;
	animation-name: menu-hover-blink;
	animation-duration: 0.46s;
	animation-iteration-count: infinite;
	animation-direction: alternate;
	animation-timing-function: ease-in-out;
	text-shadow: none;
}

#new-game-button {
	width: 150px;
	height: 34px;
}

#new-game-button .hover-image-label {
	font-size: 24px;
	font-weight: 400;
}

#continue-button {
	width: 150px;
	height: 34px;
}

#continue-button .hover-image-label {
	font-size: 24px;
	font-weight: 400;
}

#settings-button {
	width: 170px;
	height: 44px;
}

#settings-button .hover-image-label {
	font-size: 36px;
	font-weight: 700;
}

#credits-button {
	width: 150px;
	height: 44px;
}

#credits-button .hover-image-label {
	font-size: 36px;
	font-weight: 700;
}

#quit-button {
	width: 80px;
	height: 34px;
	line-height: 100%;
 bottom: auto; right: auto;}

#quit-button .hover-image-label {
	font-size: 24px;
	font-weight: 400;
}

.menu-secondary {
	display: inline-block;
	margin-right: 28px;
	font-size: 28px;
	font-weight: 400;
	line-height: 34px;
	color: #f5f2eeE6;
}

.menu-secondary:hover {
	color: #ffffffE6;
	text-shadow: none;
}

.quit-link {
	display: block;
	margin-top: 24px;
}

#stat-button {
	position: absolute;
	right: 72px;
	bottom: 72px;
	width: 72px;
	height: 72px;
}

#stat-icon {
	width: 72px;
	height: 72px;
}

#stat-button:hover {
	opacity: 0.82;
}
