<rml>
<head>
    <title>FRACTURE LINE</title>
    <link type="text/rcss" href="../Common/MenuHoverButton.rcss.bak"/>
    <link type="text/rcss" href="Title.rcss.bak"/>
</head>
<body>
    <div id="title-screen">
        <img id="title-background" src="Title.png" style="position: absolute; left: 0.00px; top: 0.00px; width: 100.00%; height: 100.00%;"/>
        <div id="shade"></div>

        <div id="main-menu">
            <div id="game-title" class="menu-root" data-ui-editor="text" style="position: absolute; left: 0.00px; top: 0.00px; width: 100.00px; height: 24.00px; font-size: 104.00px; font-weight: 900; color: #FAFAFA;">FRACTURE LINE</div>

            <div id="start-game-group" class="menu-node" style="position: absolute; left: 55.80px; top: 162.00px; width: 540.00px; height: 140.00px;">
                <div id="start-game-label" class="menu-primary" data-ui-editor="text" style="position: absolute; left: -36.00px; top: -30.00px; width: 390.00px; height: 72.00px; font-size: 60.00px; font-weight: bold; color: #FAFAFA;">START GAME</div>
                <div id="new-game-button" class="hover-image-button" style="position: absolute; left: -20.00px; top: 40.00px; width: 146.00px; height: 26.00px;">
                    <img class="hover-image-box" src="../Common/HoverCutBox.png"/>
                    <div class="hover-image-label menu-child">NEW GAME</div>
                </div>
                <div id="continue-button" class="hover-image-button" style="position: absolute; left: 140.00px; top: 40.00px; width: 140.00px; height: 26.00px;">
                    <img class="hover-image-box" src="../Common/HoverCutBox.png"/>
                    <div class="hover-image-label menu-child">CONTINUE</div>
                </div>
            </div>

            <div id="settings-button" class="hover-image-button" style="position: absolute; left: 10.00px; top: 250.00px; width: 190.00px; height: 40.00px;">
                <img class="hover-image-box" src="../Common/HoverCutBox.png"/>
                <div class="hover-image-label menu-primary">SETTINGS</div>
            </div>
            <div id="credits-button" class="hover-image-button" style="position: absolute; left: 8.00px; top: 305.00px; width: 170.00px; height: 40.00px;">
                <img class="hover-image-box" src="../Common/HoverCutBox.png"/>
                <div class="hover-image-label menu-primary">CREDITS</div>
            </div>
            <div id="quit-button" class="hover-image-button quit-link" style="position: absolute; left: 10.00px; top: 340.00px; width: 66.00px; height: 26.00px;">
                <img class="hover-image-box" src="../Common/HoverCutBox.png"/>
                <div class="hover-image-label menu-primary">QUIT</div>
            </div>
        </div>

        <div id="stat-button">
            <img id="stat-icon" src="StatIcon.png"/>
        </div>
    </div>
</body>
</rml>
