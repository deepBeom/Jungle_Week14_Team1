.credits-panel {
	background-color: #000000F9;
	border: 0px;
}

.credits-title {
	left: 54px;
	top: 42px;
	width: 760px;
	height: 54px;
	font-size: 42px;
	font-weight: bold;
	line-height: 54px;
	color: #ffffff;
}

.credits-close-button {
	position: absolute;
	left: 920px;
	top: 42px;
	width: 34px;
	height: 34px;
	font-size: 24px;
	font-weight: 400;
	line-height: 34px;
	text-align: center;
	color: #b0b0b0;
}

.credits-close-button:hover {
	color: #ffffff;
	background-color: #ffffff29;
}

.credits-title-separator {
	left: 54px;
	top: 112px;
	width: 872px;
	background-color: #ffffff;
	opacity: 0.42;
}

.credits-content {
	left: 54px;
	top: 146px;
	width: 872px;
	height: 404px;
}

.credits-section-label {
	position: absolute;
