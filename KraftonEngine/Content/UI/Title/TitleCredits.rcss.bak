	top: 0px;
	width: 872px;
	height: 30px;
	font-size: 24px;
	font-weight: 700;
	line-height: 30px;
	color: #b8b8b8;
}

.credits-team-name {
	position: absolute;
	left: 0px;
	top: 44px;
	width: 872px;
	height: 44px;
	font-size: 34px;
	font-weight: 800;
	line-height: 44px;
	color: #ffffff;
}

.credits-member {
	position: absolute;
	left: 20.00px;
	width: 872px;
	height: 32px;
	font-size: 22px;
	font-weight: 500;
	line-height: 32px;
	color: #ffffff;
	white-space: nowrap;
}

#credits-member-01 {
	top: 112px;
}

#credits-member-02 {
	top: 162px;
}

#credits-member-03 {
	top: 212px;
}

.credits-special-label {
	top: 294px;
}

.credits-special-name {
	position: absolute;
