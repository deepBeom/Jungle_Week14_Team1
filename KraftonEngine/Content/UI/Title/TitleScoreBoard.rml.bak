<rml>
<head>
    <title>Title ScoreBoard</title>
    <link type="text/rcss" href="../Common/FullWidthContentBox.rcss.bak"/>
    <link type="text/rcss" href="TitleScoreBoard.rcss.bak"/>
</head>
<body>
    <div id="scoreboard-screen">
        <div id="stat-panel" class="full-width-content-box title-stat-panel">
            <div id="stat-panel-content" class="full-width-content-box-content">
                <div class="panel-title">Scoreboard</div>
                <div class="scoreboard">
                    <div class="score-row score-header">
                        <div>Name</div>
                        <div>Stage</div>
                        <div>Time</div>
                    </div>
                    <div class="score-row">
                        <div>Empty Slot</div>
                        <div>-</div>
                        <div>--:--</div>
                    </div>
                    <div class="score-row">
                        <div>Empty Slot</div>
                        <div>-</div>
                        <div>--:--</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</rml>
