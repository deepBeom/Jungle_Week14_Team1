+		DrawShadowCasters(DC, *Ctx.Scene, Ctx.Resources, LightFrustum, bUseGpuSkinning, nullptr, true);
 		SHADOW_STATS_ADD_CASTER(DirectionalLight, LastDrawCasterCount);
 
